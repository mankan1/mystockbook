# Copy this file to .env.local and fill in your values
# Never commit .env.local to git

# Your Railway backend URL (for live /ES price feed)
YAHOO_PROXY_URL=https://stkbt-production-6bad.up.railway.app

# Keystatic CMS — GitHub OAuth
# Create at: github.com/settings/developers → New OAuth App
# Callback URL: http://localhost:3000/api/keystatic/github/oauth/callback (local)
#               https://your-vercel-url.vercel.app/api/keystatic/github/oauth/callback (prod)
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=

# Generate with: openssl rand -base64 32
KEYSTATIC_SECRET=
